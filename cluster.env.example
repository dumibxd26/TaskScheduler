# ─────────────────────────────────────────────────────────────────────────
# TaskScheduler — two-host k3s cluster configuration.
#
# Copy to `cluster.env` and edit the IPs to match your LAN.
# Both scripts/k3s-server.sh and scripts/k3s-agent.sh source this file.
#
# Topology:
#   pc1 (master, amd64, Linux)      — Ryzen 7 PRO 8840HS / 64 GB
#                                     runs: k3s server + 3 extra agents in VMs
#                                     hosts logical nodes:
#                                         ts-pc1            (k3s server, control-plane taint)
#                                         ts-node-cpu-1     (CPU_OPT, VM)
#                                         ts-node-cpu-2     (CPU_OPT, VM)
#                                         ts-node-io-1      (IO_OPT,  VM)
#   pc2 (slave,  arm64, macOS+VM)   — Mac mini M2 / 8 GB
#                                     runs: k3s agent inside one Linux VM
#                                     hosts logical node:
#                                         ts-node-mem-1     (MEM_OPT, passive cooling)
# ─────────────────────────────────────────────────────────────────────────

# ── LAN addresses ─────────────────────────────────────────────────────
# IP that the k3s API server listens on (= pc1's LAN IP). All agents
# connect to https://${SERVER_IP}:6443.
SERVER_IP=192.168.1.10        # ← EDIT: pc1 (laptop) LAN IP

# IP of the Mac mini host (only used for docs; the agent runs in a VM
# whose IP is auto-assigned by Multipass and joins via SERVER_IP).
PC2_HOST_IP=192.168.1.11      # ← EDIT: pc2 (Mac mini) LAN IP

# ── Cluster identity ──────────────────────────────────────────────────
CLUSTER_NAME=ts-cluster
CLUSTER_TOKEN=ts-thesis-shared-token-change-me   # ← EDIT: any string, both sides must match

# ── Container registry on pc1 (insecure HTTP — LAN only) ──────────────
REGISTRY_HOST=192.168.1.10    # ← EDIT: same as SERVER_IP unless registry runs elsewhere
REGISTRY_PORT=5000
REGISTRY="${REGISTRY_HOST}:${REGISTRY_PORT}"

# ── Image tag (must match k8s manifests + examples/tasktemplates.yaml) ─
IMAGE_TAG=v1

# ── Per-node capacity hints (advisory labels consumed by services/k8s_cluster.py) ──
# Format: NODE_CAP_<role>="cpu memory_mi cooling-class"
NODE_CAP_PC1_SERVER="4 8192 STANDARD"   # control-plane host
NODE_CAP_CPU_1="4 4096 HIGH"            # pc1 VM
NODE_CAP_CPU_2="4 4096 STANDARD"        # pc1 VM
NODE_CAP_IO_1="2 4096 STANDARD"         # pc1 VM
NODE_CAP_MEM_1="2 4096 PASSIVE"         # pc2 (Mac mini, passively cooled)
