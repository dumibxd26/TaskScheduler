# ─────────────────────────────────────────────────────────────────────────
# TaskScheduler — two-host k3s cluster configuration.
#
# Copy to `cluster.env` and edit the IPs to match your LAN.
# Both scripts/k3s-server.sh and scripts/k3s-agent.sh source this file.
#
# Topology:
#   pc1 (MASTER, arm64, macOS + Multipass) — Mac mini M2 / 8 GB
#                                     runs: k3s server inside a Linux VM
#                                     hosts logical node:
#                                         ts-master         (control plane, MEM_OPT, PASSIVE)
#   pc2 (WORKER, amd64, Windows + Multipass) — Ryzen 7 PRO 8840HS / 64 GB
#                                     runs: 4 k3s agents in Multipass VMs
#                                     hosts logical nodes:
#                                         ts-node-cpu-1     (CPU_OPT, HIGH cooling)
#                                         ts-node-cpu-2     (CPU_OPT, STANDARD)
#                                         ts-node-io-1      (IO_OPT,  STANDARD)
#                                         ts-node-mem-1     (MEM_OPT, STANDARD)
#
# k3s does not run natively on macOS or Windows, so on both machines
# the k3s processes live inside Multipass Linux VMs. The cross-host LAN
# hop between pc1's master VM and pc2's worker VMs is what gives
# ts-bw-probe something real to measure.
# ─────────────────────────────────────────────────────────────────────────

# ── LAN addresses ─────────────────────────────────────────────────────
# IP that the k3s API server listens on. This must be the IP of the
# MASTER VM running on pc1 (Mac mini). Multipass on macOS bridges the
# VM onto the LAN, so this IP is reachable from pc2. After running
# scripts/k3s-server.sh on pc1, the script prints the VM's IP — put it
# here and copy this file to pc2.
SERVER_IP=192.168.1.20        # ← EDIT after `make k3s-server` on pc1

# Host IPs (only used by docs / firewall rules; the cluster itself
# connects exclusively through SERVER_IP).
PC1_HOST_IP=192.168.1.10      # ← EDIT: pc1 (Mac mini) LAN IP
PC2_HOST_IP=192.168.1.11      # ← EDIT: pc2 (Windows laptop) LAN IP

# ── Cluster identity ──────────────────────────────────────────────────
CLUSTER_NAME=ts-cluster
CLUSTER_TOKEN=ts-thesis-shared-token-change-me   # ← EDIT: any string, both sides must match

# ── Container registry (insecure HTTP — LAN only) ─────────────────────
# Runs inside the master VM on pc1. Multi-arch images (amd64+arm64)
# live here so the Windows workers (amd64) and the Mac mini master
# (arm64) can pull the same tag.
REGISTRY_HOST="${SERVER_IP}"
REGISTRY_PORT=5000
REGISTRY="${REGISTRY_HOST}:${REGISTRY_PORT}"

# ── Image tag (must match k8s manifests + examples/tasktemplates.yaml) ─
IMAGE_TAG=v1

# ── Master VM sizing (pc1 — Mac mini, 8 GB total) ─────────────────────
# Keep modest: macOS itself needs 2-3 GB, leaving ~5 GB for the VM.
MASTER_VM_CPUS=3
MASTER_VM_MEM_GB=4
MASTER_VM_DISK_GB=20

# ── Per-node capacity hints (advisory labels consumed by services/k8s_cluster.py) ──
# Format: NODE_CAP_<role>="cpu memory_mi cooling-class"
NODE_CAP_MASTER="3 4096 PASSIVE"        # pc1 master VM (Mac mini, passively cooled)
NODE_CAP_CPU_1="4 4096 HIGH"            # pc2 VM
NODE_CAP_CPU_2="4 4096 STANDARD"        # pc2 VM
NODE_CAP_IO_1="2 4096 STANDARD"         # pc2 VM
NODE_CAP_MEM_1="2 8192 STANDARD"        # pc2 VM (plenty of RAM on laptop)
